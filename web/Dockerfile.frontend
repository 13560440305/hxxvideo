# Build
FROM node:20-alpine AS builder
WORKDIR /app
COPY web/frontend/package.json web/frontend/package-lock.json* ./
RUN npm ci
COPY web/frontend/ .
RUN npm run build

# Serve
FROM nginx:alpine
COPY --from=builder /app/out /usr/share/nginx/html
COPY --from=builder /app/out/_next /usr/share/nginx/html/_next
