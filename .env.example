# =============================================================================
# StarVoyage AI Video Engine — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys (or set them in config.yaml).
#
# Environment variables take precedence over config.yaml values.
# =============================================================================

# ── OpenRouter (LLM API) ──────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ── SiliconFlow (Video / Image Generation) ────────────────────────────────────
SILICONFLOW_API_KEY=sf-your_siliconflow_key_here

# ── Config file path (optional — defaults to src/config/config.yaml) ──────────
# STARVOYAGE_CONFIG=/path/to/custom/config.yaml
